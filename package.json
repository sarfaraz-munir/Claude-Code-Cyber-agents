{
  "name": "ciso-agents",
  "version": "1.0.0",
  "description": "CISO-grade cybersecurity swarm: hierarchical orchestrator with 9 specialist AI agents covering risk, compliance, threat intelligence, architecture, IR, vuln-mgmt, DevSecOps, awareness, and AI security",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ciso-agents-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run --no-coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "mcp:serve": "tsx src/mcp-server.ts",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^3.2.7",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "ciso",
    "cybersecurity",
    "risk-management",
    "compliance",
    "threat-intelligence",
    "incident-response",
    "vulnerability-management",
    "devsecops",
    "swarm",
    "multi-agent",
    "owasp",
    "mitre-attack",
    "ai-security",
    "nist",
    "gdpr",
    "soc2"
  ],
  "author": "Sarfaraz Munir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarfaraz-munir/Claude-Code-Cyber-agents.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
